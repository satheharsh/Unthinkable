generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  PATIENT
  DOCTOR
  ADMIN
}

enum AppointmentStatus {
  AVAILABLE
  ON_HOLD
  BOOKED
  CANCELLED
  CANCELLED_DUE_TO_LEAVE
}

model User {
  id                  String        @id @default(uuid())
  email               String        @unique
  name                String
  role                Role          @default(PATIENT)
  specialization      String?
  password            String?
  
  patientAppointments Appointment[] @relation("PatientAppointments")
  doctorAppointments  Appointment[] @relation("DoctorAppointments")
  
  startTime           String?       @default("09:00")
  endTime             String?       @default("17:00")
  slotDurationMinutes Int?          @default(30)
  
  waitlists           Waitlist[]
  leaves              DoctorLeave[]
  
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
}

model Appointment {
  id              String            @id @default(uuid())
  patientId       String?
  patient         User?             @relation("PatientAppointments", fields: [patientId], references: [id])
  
  doctorId        String
  doctor          User              @relation("DoctorAppointments", fields: [doctorId], references: [id])
  
  slotTime        DateTime
  status          AppointmentStatus @default(AVAILABLE)
  holdExpiresAt   DateTime?
  meetLink        String?
  calendarEventId String?
  symptoms        String?           @db.Text
  preVisitSummary String?           @db.Text
  doctorNotes     String?           @db.Text
  postVisitSummary String?          @db.Text
  aiSummaryFailed Boolean           @default(false)
  
  llmSummary      LLMSummary?
  waitlistEntries Waitlist[]
  
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  // Prevents double booking at DB schema level if slots are predefined
  @@unique([doctorId, slotTime]) 
}

model LLMSummary {
  id             String       @id @default(uuid())
  appointmentId  String       @unique
  appointment    Appointment  @relation(fields: [appointmentId], references: [id])
  summaryText    String       @db.Text
  medicationSchedule Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Waitlist {
  id             String       @id @default(uuid())
  appointmentId  String
  appointment    Appointment  @relation(fields: [appointmentId], references: [id])
  userId         String
  user           User         @relation(fields: [userId], references: [id])
  notified       Boolean      @default(false)
  notifiedAt     DateTime?
  
  createdAt      DateTime     @default(now())

  // A user can only be on the waitlist for a specific appointment slot once
  @@unique([appointmentId, userId])
}

model DoctorLeave {
  id             String       @id @default(uuid())
  doctorId       String
  doctor         User         @relation(fields: [doctorId], references: [id])
  startTime      DateTime
  endTime        DateTime
  reason         String?
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model NotificationQueue {
  id          String   @id @default(uuid())
  type        String   
  recipient   String
  subject     String?
  message     String   @db.Text
  status      String   @default("PENDING") 
  retryCount  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AuditLog {
  id          String   @id @default(uuid())
  userId      String
  action      String
  patientId   String?
  details     String?
  createdAt   DateTime @default(now())
}
